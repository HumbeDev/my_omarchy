#!/bin/bash

# omarchy:summary=Install Docker and related tools (Buildx, Compose, LazyDocker, UFW-Docker).

echo "Instalando Docker y herramientas relacionadas..."
sudo pacman -S --needed docker docker-buildx docker-compose lazydocker ufw-docker

echo "Configurando Docker al estilo Omarchy..."
# Configurar demonio (logs y DNS)
sudo mkdir -p /etc/docker
sudo tee /etc/docker/daemon.json >/dev/null <<'EOF'
{
    "log-driver": "json-file",
    "log-opts": { "max-size": "10m", "max-file": "5" },
    "dns": ["172.17.0.1"],
    "bip": "172.17.0.1/16"
}
EOF

# Exponer systemd-resolved a la red de Docker
sudo mkdir -p /etc/systemd/resolved.conf.d
echo -e '[Resolve]\nDNSStubListenerExtra=172.17.0.1' | sudo tee /etc/systemd/resolved.conf.d/20-docker-dns.conf >/dev/null
sudo systemctl restart systemd-resolved

# Habilitar Docker por socket (on-demand)
sudo systemctl enable docker.socket

# Agregar usuario al grupo docker
sudo usermod -aG docker ${USER}

# Evitar que Docker bloquee el arranque si no hay red
sudo mkdir -p /etc/systemd/system/docker.service.d
sudo tee /etc/systemd/system/docker.service.d/no-block-boot.conf <<'EOF'
[Unit]
DefaultDependencies=no
EOF

sudo systemctl daemon-reload

echo "Configurando UFW para Docker..."
sudo ufw-docker install

echo "Instalación completada. Por favor, reinicia tu sesión para aplicar los cambios de grupo."
